# Fursay newsletter automation
# Copy this file to .env locally, then fill the values.

# Optional legacy mode only.
# The Codex automation workflow generates copy itself and does not need this.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# YouTube Data API v3
YOUTUBE_API_KEY=

# MailerLite API and target groups
MAILERLITE_API_TOKEN=
MAILERLITE_GROUP_KOKO=
MAILERLITE_GROUP_NOOR=

# Keep false on Free plan. MailerLite's campaign content API requires
# Advanced plan support for emails.*.content.
# Free-plan automation should use --mode chrome-handoff and logged-in Chrome
# instead of non-dry-run --mode send.
MAILERLITE_ALLOW_CONTENT_API_SEND=false

# MailerLite sender identity.
# The from/reply-to addresses must already be verified in MailerLite.
NEWSLETTER_FROM_EMAIL=
NEWSLETTER_FROM_NAME=Fursay
NEWSLETTER_REPLY_TO=

# Optional. If omitted, MailerLite uses the account timezone.
# Keep the MailerLite account timezone set to Asia/Taipei, or set this to
# the MailerLite timezone id for Asia/Taipei if your account requires it.
MAILERLITE_TIMEZONE_ID=

# Optional API scheduling overrides. The runner defaults to Monday 09:00 for
# Koko and Wednesday 09:00 for Arabic when these are omitted.
NEWSLETTER_DEFAULT_TIME=09:00

# Operational contact for Codex automation reports.
ADMIN_EMAIL=

# Cloudflare deploy and anonymous analytics reporting.
# Keep these unset unless you are running deploy readiness or event reports.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ANALYTICS_TOKEN=
