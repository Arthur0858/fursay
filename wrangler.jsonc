{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "fursay",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-28",
  "keep_vars": true,
  "assets": {
    "directory": "./fursay-optimized-site",
    "binding": "ASSETS",
    "html_handling": "none",
    "run_worker_first": true
  },
  "analytics_engine_datasets": [
    {
      "binding": "FURSAY_EVENTS",
      "dataset": "fursay_events"
    }
  ]
}
