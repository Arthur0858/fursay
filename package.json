{
  "name": "fursay-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "assets:fingerprints": "node scripts/update-immutable-asset-fingerprints.mjs",
    "assets:fingerprints:check": "node scripts/update-immutable-asset-fingerprints.mjs --check",
    "check": "node scripts/release-fursay.mjs --check-only",
    "deploy:ready": "node scripts/check-deploy-readiness.mjs",
    "deploy": "node scripts/release-fursay.mjs",
    "deploy:push": "node scripts/release-fursay.mjs --push-git",
    "analytics:enablement:check": "node scripts/check-analytics-enablement-contract.mjs",
    "noor:sprint:log": "node scripts/record-noor-sprint-log.mjs",
    "noor:sprint:next": "node scripts/next-noor-sprint-action.mjs",
    "noor:sprint:review": "node scripts/review-noor-sprint-report.mjs",
    "report:events": "node scripts/query-event-analytics-report.mjs",
    "smoke:live": "node scripts/smoke-live.mjs"
  },
  "devDependencies": {
    "playwright": "^1.56.0",
    "sharp": "^0.34.5",
    "wrangler": "^4.100.0"
  }
}
